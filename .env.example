# LLM Provider: "ollama" (local, default) or "openai" (cloud)
LLM_PROVIDER=ollama

# Ollama settings (local - default)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# OpenAI settings (cloud - optional)
# Set LLM_PROVIDER=openai to use OpenAI instead of local Ollama
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o-mini
TAVILY_API_KEY=tvly-your-api-key-here

LLM_MAX_CONCURRENT=3
SUGGESTION_CACHE_TTL_MINUTES=30
SUGGESTION_COUNT=14
HEADLESS=true
ALLOW_FINAL_SUBMIT=false
DEFAULT_RESUME_PATH=./data/resumes/sample_resume.txt
DEFAULT_PROFILE_PATH=./data/profiles/profile.json
LOG_LEVEL=INFO
DATABASE_PATH=./data/linkedin_copilot.sqlite3
DRY_RUN=true